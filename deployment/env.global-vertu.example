# global@vertu.com production mailbox profile.
# Copy these values into production.env and fill the client-specific password.

MAIL_PROVIDER=smtp
MAIL_FROM_EMAIL=global@vertu.com

SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USER=global@vertu.com
SMTP_PASSWORD=
SMTP_SECURITY=ssl
SMTP_ENVELOPE_FROM=global@vertu.com
SMTP_ALLOW_FROM_ALIAS=false
IMAP_HOST=imap.exmail.qq.com
IMAP_PORT=993
IMAP_USER=global@vertu.com
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_LOOKBACK_DAYS=14
MAILBOX_POLL_INTERVAL_SECONDS=60

OUTBOUND_IDENTITY_MODE=legacy
OUTBOUND_SENDING_DOMAIN=global.vertu.com
OUTBOUND_REPLY_DOMAIN=reply.global.vertu.com

# Keep tracking secrets independent. Generate production values; do not commit them.
REPLY_ROUTING_SECRET=replace-with-at-least-32-random-characters
TRACKING_SIGNING_SECRET=replace-with-another-at-least-32-random-characters
# Resend is optional because replies are ingested from the mailbox through IMAP.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

PUBLIC_BASE_URL=https://global-autoleads.vertu.cn
